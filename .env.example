# === API KEYS ===
OUTSCRAPER_API_KEY=your_outscraper_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
RESEND_API_KEY=your_resend_key_here

# === OUTSCRAPER LEAD QUERIES ===
# Comma-separated Google Maps queries targeting Mexican businesses that need websites
OUTSCRAPER_QUERIES=restaurantes en Ciudad de Mexico,salones de belleza en CDMX,talleres mecanicos en Guadalajara,dentistas en Monterrey,plomeros en Puebla,contadores en Guadalajara,veterinarias en Ciudad de Mexico,tiendas de ropa en Monterrey,gimnasios en CDMX,floristerias en Puebla
OUTSCRAPER_LIMIT=20

# === SCHEDULER ===
LOOP_INTERVAL_SECONDS=3600

# === FOLLOW-UP ===
FOLLOWUP_DAYS=3

# === REPLY SIMULATION (testing) ===
# Probability 0.0 to 1.0 that a contacted lead sends a reply each cycle
REPLY_SIMULATION_CHANCE=0.15

# === EMAIL SENDER ===
FROM_EMAIL=hola@alcocerstudios.com
FROM_NAME=Alcocer Studios

# === SAFETY ===
# Max outreach emails sent per calendar day
DAILY_SEND_LIMIT=30

# === LOGGING ===
LOG_LEVEL=INFO
